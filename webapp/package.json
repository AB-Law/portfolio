{
  "name": "webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:seo": "node scripts/generate-seo-assets.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "build": "npm run validate:content && npm run build:seo && tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "quality": "npm run lint && npm run format && npm run typecheck && npm run test",
    "lint": "eslint .",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=dot",
    "build:ci": "npm run validate:content && npm run lint && npm run typecheck && npm run build && npm run check:bundle-size",
    "prepare": "husky",
    "preview": "vite preview"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --cache --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{css,html,md,mdx,json,yml,yaml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "^2.1.1",
    "mermaid": "^11.12.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.8",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
